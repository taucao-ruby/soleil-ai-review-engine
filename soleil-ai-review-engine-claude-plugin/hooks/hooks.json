{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/soleil-ai-review-engine-hook.js",
            "timeout": 10,
            "statusMessage": "Enriching with soleil-ai-review-engine graph context..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/hooks/soleil-ai-review-engine-hook.js",
            "timeout": 10,
            "statusMessage": "Checking soleil-ai-review-engine index freshness..."
          }
        ]
      }
    ]
  }
}
